# Copy these into the Render dashboard (Environment tab). Do not commit secrets.

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
PYTHON_VERSION=3.11.9

# Relative to repo root when rootDir is phase6_backend_api
DATA_PATH=../phase1_data_ingestion/data/processed/restaurants.parquet

# Production Vercel URL (update after first Vercel deploy)
CORS_ORIGINS=https://bitewise-ai.vercel.app,http://localhost:3000

# Allow Vercel preview deployments (*.vercel.app)
CORS_ALLOW_VERCEL_PREVIEWS=true
